#!/bin/sh
# M8Shift pre-push scrub gate (RFC 052 E2) — the last safe moment before content
# leaves the machine.
#
# ADVISORY and LOCAL by default: findings are printed, the push proceeds. Set
# M8SHIFT_SCRUB_ENFORCE=1 to BLOCK the push on findings. Scanner ERRORS always
# fail open (printed, never blocking) — a broken scanner must not freeze pushes.
# `git push --no-verify` bypasses this hook entirely, by design (git semantics).
#
# What runs:
#   1. `m8shift.py doctor --hygiene-only --lint` — the RFC 052 C1+C3 data-hygiene
#      lint (real home paths + operator-confidential denylist, redacted output).
#   2. `checksums.sha256` (if present) — verifies that shipped artifacts still
#      match the release manifest. Mismatches follow the same advisory/enforce
#      policy as scrub findings; verifier errors fail open.
#   3. `scripts/scrub-check.py` (if present) — the denylist over WHAT THIS PUSH
#      PUBLISHES: git feeds the hook one `<local ref> <local sha> <remote ref>
#      <remote sha>` line per ref on stdin, and each becomes a `--range`
#      (remote..local; a bare local sha when the remote side is new or unknown;
#      deletions are skipped — nothing leaves). Raw git, never a lossy optimizer.
#      Scanning only the pushed ranges keeps the hook fast — a full-history walk
#      per push trains a `--no-verify` reflex that rots the gate. The full walk
#      remains available (CI, audits): run scrub-check.py without --range.
#      rc 1 = hit, rc >= 2 = scanner error (fail open).
#
# Install (per clone, hooks are not version-controlled by Git):
#   git config core.hooksPath hooks
#   (or: cp hooks/pre-push <repo>/.git/hooks/pre-push && chmod +x it)

set -eu

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || printf '.')"

# Resolve the m8shift.py program (soft: everything here is advisory-by-default).
m8shift=""
if [ -n "${M8SHIFT_BIN:-}" ] && [ -x "${M8SHIFT_BIN}" ]; then
	m8shift="${M8SHIFT_BIN}"
elif command -v m8shift.py >/dev/null 2>&1; then
	m8shift="m8shift.py"
elif [ -x "${repo_root}/m8shift.py" ]; then
	m8shift="${repo_root}/m8shift.py"
fi

block=0

# --- 1. data-hygiene lint (C1 paths + C3 denylist, redacted) ---------------------
if [ -n "${m8shift}" ]; then
	hygiene_rc=0
	"${m8shift}" doctor --hygiene-only --lint >&2 || hygiene_rc=$?
	if [ "${hygiene_rc}" -eq 1 ]; then
		block=1
	elif [ "${hygiene_rc}" -gt 1 ]; then
		printf '%s\n' "m8shift pre-push: hygiene scanner failed (rc ${hygiene_rc}) — continuing without it." >&2
	fi
fi

# --- 2. release checksum manifest ------------------------------------------------
manifest="${repo_root}/checksums.sha256"
if [ -f "${manifest}" ]; then
	checksum_rc=0
	if command -v sha256sum >/dev/null 2>&1; then
		(cd "${repo_root}" && sha256sum -c checksums.sha256) >&2 || checksum_rc=$?
	elif command -v shasum >/dev/null 2>&1; then
		(cd "${repo_root}" && shasum -a 256 -c checksums.sha256) >&2 || checksum_rc=$?
	else
		checksum_rc=2
	fi
	if [ "${checksum_rc}" -eq 1 ]; then
		printf '%s\n' "m8shift pre-push: checksums.sha256 is stale or invalid." >&2
		block=1
	elif [ "${checksum_rc}" -gt 1 ]; then
		printf '%s\n' "m8shift pre-push: checksum verification failed (rc ${checksum_rc}) — continuing without it." >&2
	fi
fi

# --- 3. denylist scrub over the pushed ranges (E1) --------------------------------
# Git's pre-push stdin: one `<local ref> <local sha> <remote ref> <remote sha>`
# line per ref being pushed. Only read it when stdin is NOT a terminal (a manual
# `sh hooks/pre-push` run from a shell has no ref lines — fall back to the full
# tip+history scan rather than hang on a read).
ranges=""
stdin_lines=0
if [ ! -t 0 ]; then
	while read -r _local_ref local_sha _remote_ref remote_sha; do
		[ -n "${local_sha:-}" ] || continue
		stdin_lines=$((stdin_lines + 1))
		case "${local_sha}" in
		*[!0]*) ;;                       # has a non-zero digit: a real object
		*) continue ;;                   # all zeros: a DELETION — nothing leaves
		esac
		case "${remote_sha:-}" in
		"" ) ranges="${ranges} --range ${local_sha}" ;;
		*[!0]*)
			# Known remote base -> scan exactly the new commits. If the base
			# object is absent locally (stale tracking), the bare-sha form
			# over-scans (--not --remotes) instead of erroring out.
			if git cat-file -e "${remote_sha}^{commit}" 2>/dev/null; then
				ranges="${ranges} --range ${remote_sha}..${local_sha}"
			else
				ranges="${ranges} --range ${local_sha}"
			fi
			;;
		*) ranges="${ranges} --range ${local_sha}" ;;   # new branch/tag
		esac
	done
fi

scrub="${repo_root}/scripts/scrub-check.py"
if [ -f "${scrub}" ]; then
	if [ "${stdin_lines}" -gt 0 ] && [ -z "${ranges}" ]; then
		# Every pushed ref was a deletion: nothing new leaves the machine.
		printf '%s\n' "m8shift pre-push: deletion-only push — scrub skipped (nothing published)." >&2
	else
		scrub_rc=0
		# shellcheck disable=SC2086 # intentional word-splitting: hex-only rev specs
		python3 "${scrub}" --repo "${repo_root}" ${ranges} >&2 || scrub_rc=$?
		if [ "${scrub_rc}" -eq 1 ]; then
			block=1
		elif [ "${scrub_rc}" -ge 2 ]; then
			printf '%s\n' "m8shift pre-push: scrub-check failed (rc ${scrub_rc}) — continuing without it." >&2
		fi
	fi
fi

if [ "${block}" -eq 1 ]; then
	if [ "${M8SHIFT_SCRUB_ENFORCE:-0}" = "1" ]; then
		printf '%s\n' "m8shift pre-push: gate findings above and M8SHIFT_SCRUB_ENFORCE=1 — push blocked. Fix the findings or unset the enforce variable." >&2
		exit 1
	fi
	printf '%s\n' "m8shift pre-push: gate findings above are ADVISORY (set M8SHIFT_SCRUB_ENFORCE=1 to block on them); pushing anyway." >&2
fi

exit 0
