{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "m8shift.route-decision.v1",
  "title": "M8Shift immutable model-line route decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "decision_id", "recorded_at", "session", "run_id", "agent",
    "provider", "requested_model", "selected_model", "policy_id", "reason_code",
    "switch_ordinal", "adapter", "evidence_refs", "checkpoint"
  ],
  "properties": {
    "schema": {"const": "m8shift.route-decision.v1"},
    "decision_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "session": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "agent": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "requested_model": {"type": "string", "minLength": 1},
    "selected_model": {"type": ["string", "null"], "minLength": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "reason_code": {"type": "string", "minLength": 1},
    "switch_ordinal": {"type": "integer", "minimum": 0},
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "captured_at", "freshness"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "captured_at": {"type": "string", "format": "date-time"},
          "freshness": {"enum": ["fresh", "stale", "unknown"]}
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_plan_ref", "attempt_plan_sha256", "relay_session", "relay_turn",
        "relay_turn_sha256", "relay_state", "completed_invocation", "next_invocation"
      ],
      "properties": {
        "attempt_plan_ref": {"type": "string", "minLength": 1},
        "attempt_plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "relay_session": {"type": "string", "minLength": 1},
        "relay_turn": {"type": "integer", "minimum": 0},
        "relay_turn_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "relay_state": {"type": "string", "pattern": "^(IDLE|AWAITING_[A-Z0-9_-]+|PAUSED|DONE)$"},
        "completed_invocation": {"type": "integer", "minimum": 0},
        "next_invocation": {"type": "integer", "minimum": 1}
      }
    }
  }
}
